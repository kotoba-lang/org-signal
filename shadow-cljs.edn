;; CLJS test build for the cljs sibling of this package's JVM signal impl.
;; Not part of the shipped JVM deps.edn — this is dev/test tooling only.
;; run: pnpm exec shadow-cljs compile test && node out/node-tests.js
{:deps {:aliases [:cljs-test]}
 :builds
 {:test
  {:target :node-test
   :output-to "out/node-tests.js"
   :ns-regexp "-test$"}}}
